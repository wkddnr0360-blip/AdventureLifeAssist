rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        (
          request.auth.token.email == 'wkddnr0360@naver.com' &&
          request.auth.token.email_verified == true
        )
      );
    }

    function validShortText(value, maxLength) {
      return value is string && value.size() <= maxLength;
    }

    function validDateKey(value) {
      return value is string && value.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function validHandle(value) {
      return value is string && value.matches('^[a-z0-9_.]{3,20}$');
    }

    function validActiveSession(session) {
      return session == null || (
        session is map &&
        session.keys().hasOnly([
          'id', 'subject', 'startProblem', 'targetMinutes', 'goalCount',
          'startNote', 'alarmId', 'startedAtMs', 'pausedAtMs',
          'pausedTotalMs', 'targetNotified', 'createdAtMs', 'deviceId',
          'revision', 'updatedAtMs'
        ]) &&
        validShortText(session.id, 100) &&
        validShortText(session.subject, 30) &&
        validShortText(session.startProblem, 30) &&
        session.targetMinutes is int && session.targetMinutes >= 1 && session.targetMinutes <= 240 &&
        (!('goalCount' in session) || session.goalCount == null || (session.goalCount is int && session.goalCount >= 1 && session.goalCount <= 9999)) &&
        (!('startNote' in session) || validShortText(session.startNote, 160)) &&
        (!('alarmId' in session) || session.alarmId == null || validShortText(session.alarmId, 100)) &&
        session.startedAtMs is int &&
        (!('pausedAtMs' in session) || session.pausedAtMs == null || session.pausedAtMs is int) &&
        session.pausedTotalMs is int && session.pausedTotalMs >= 0 &&
        session.targetNotified is bool &&
        session.createdAtMs is int &&
        (!('deviceId' in session) || validShortText(session.deviceId, 120)) &&
        (!('revision' in session) || (session.revision is int && session.revision >= 0)) &&
        (!('updatedAtMs' in session) || session.updatedAtMs is int)
      );
    }

    function isConversationMember(appId, conversationId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/apps/$(appId)/conversations/$(conversationId)).data.memberIds;
    }


    function onlyOwnReadReceiptChanged() {
      return request.resource.data.readAt is map &&
        resource.data.readAt is map &&
        request.resource.data.readAt.diff(resource.data.readAt).affectedKeys().hasOnly([request.auth.uid]);
    }

    function validLikeToggle() {
      let before = resource.data.likedBy;
      let after = request.resource.data.likedBy;
      return before is list && after is list &&
        after.size() <= 500 &&
        after.size() == after.toSet().size() &&
        after.toSet().difference(before.toSet()).hasOnly([request.auth.uid]) &&
        before.toSet().difference(after.toSet()).hasOnly([request.auth.uid]) &&
        (
          (!(request.auth.uid in before) && request.auth.uid in after && after.size() == before.size() + 1) ||
          (request.auth.uid in before && !(request.auth.uid in after) && after.size() == before.size() - 1)
        );
    }

    match /apps/{appId} {
      allow read: if appId == 'focusbell_v1' && isAdmin();
      allow write: if false;

      match /handles/{handle} {
        allow read: if appId == 'focusbell_v1' && signedIn();
        allow create: if appId == 'focusbell_v1' && signedIn() &&
          validHandle(handle) &&
          request.resource.data.keys().hasOnly(['handle', 'uid', 'createdAtMs', 'updatedAtMs']) &&
          request.resource.data.handle == handle &&
          request.resource.data.uid == request.auth.uid;
        allow update: if appId == 'focusbell_v1' && signedIn() &&
          resource.data.uid == request.auth.uid &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.handle == handle &&
          request.resource.data.keys().hasOnly(['handle', 'uid', 'createdAtMs', 'updatedAtMs']);
        allow delete: if appId == 'focusbell_v1' && signedIn() && resource.data.uid == request.auth.uid;
      }

      match /users/{userId} {
        allow read: if appId == 'focusbell_v1' && (isOwner(userId) || isAdmin());
        allow create: if appId == 'focusbell_v1' && isOwner(userId) &&
          request.resource.data.uid == userId &&
          request.resource.data.email == request.auth.token.email &&
          request.resource.data.keys().hasOnly([
            'uid', 'email', 'displayName', 'handle', 'bio', 'createdAtMs',
            'updatedAtMs', 'activeSession', 'dailyMinutesGoal',
            'dailyProblemsGoal', 'showInRanking', 'shareStudyStatus',
            'showOnlineStatus', 'tutorialCompletedAtMs'
          ]) &&
          validShortText(request.resource.data.displayName, 24) &&
          validHandle(request.resource.data.handle) &&
          validShortText(request.resource.data.bio, 100) &&
          validActiveSession(request.resource.data.activeSession);
        allow update: if appId == 'focusbell_v1' && isOwner(userId) &&
          request.resource.data.uid == userId &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.email == request.auth.token.email &&
          request.resource.data.keys().hasOnly([
            'uid', 'email', 'displayName', 'handle', 'bio', 'createdAtMs',
            'updatedAtMs', 'activeSession', 'dailyMinutesGoal',
            'dailyProblemsGoal', 'showInRanking', 'shareStudyStatus',
            'showOnlineStatus', 'tutorialCompletedAtMs'
          ]) &&
          validShortText(request.resource.data.displayName, 24) &&
          validHandle(request.resource.data.handle) &&
          validShortText(request.resource.data.bio, 100) &&
          validActiveSession(request.resource.data.activeSession) &&
          (!('dailyMinutesGoal' in request.resource.data) || (request.resource.data.dailyMinutesGoal is int && request.resource.data.dailyMinutesGoal >= 1 && request.resource.data.dailyMinutesGoal <= 1440)) &&
          (!('dailyProblemsGoal' in request.resource.data) || (request.resource.data.dailyProblemsGoal is int && request.resource.data.dailyProblemsGoal >= 1 && request.resource.data.dailyProblemsGoal <= 9999));
        allow delete: if false;

        match /alarms/{alarmId} {
          allow read: if appId == 'focusbell_v1' && (isOwner(userId) || isAdmin());
          allow create, update: if appId == 'focusbell_v1' && isOwner(userId) &&
            request.resource.data.id == alarmId &&
            request.resource.data.keys().hasOnly([
              'id', 'label', 'defaultSubject', 'defaultStartProblem',
              'targetMinutes', 'note', 'repeatDays', 'timeOfDay',
              'scheduledAtMs', 'enabled', 'createdAtMs', 'updatedAtMs',
              'lastTriggeredAtMs', 'missedAtMs'
            ]) &&
            validShortText(request.resource.data.label, 40) &&
            validShortText(request.resource.data.defaultSubject, 30) &&
            validShortText(request.resource.data.defaultStartProblem, 30) &&
            validShortText(request.resource.data.note, 160) &&
            request.resource.data.targetMinutes is int &&
            request.resource.data.targetMinutes >= 1 && request.resource.data.targetMinutes <= 240 &&
            request.resource.data.repeatDays is list && request.resource.data.repeatDays.size() <= 7 &&
            validShortText(request.resource.data.timeOfDay, 5) &&
            request.resource.data.scheduledAtMs is int &&
            request.resource.data.enabled is bool;
          allow delete: if appId == 'focusbell_v1' && isOwner(userId);
        }

        match /logs/{logId} {
          allow read: if appId == 'focusbell_v1' && (isOwner(userId) || isAdmin());
          allow create: if appId == 'focusbell_v1' && isOwner(userId) &&
            request.resource.data.id == logId &&
            request.resource.data.keys().hasOnly([
              'id', 'subject', 'startProblem', 'endProblem', 'durationSec',
              'targetMinutes', 'goalCount', 'solvedCount', 'correctCount',
              'startNote', 'reflection', 'startedAtMs', 'endedAtMs',
              'status', 'createdAtMs', 'completedByDeviceId', 'sessionId'
            ]) &&
            validShortText(request.resource.data.subject, 30) &&
            validShortText(request.resource.data.startProblem, 30) &&
            validShortText(request.resource.data.endProblem, 30) &&
            request.resource.data.durationSec is int && request.resource.data.durationSec >= 0 &&
            request.resource.data.solvedCount is int && request.resource.data.solvedCount >= 0 && request.resource.data.solvedCount <= 99999 &&
            (!('correctCount' in request.resource.data) || request.resource.data.correctCount == null || (request.resource.data.correctCount is int && request.resource.data.correctCount >= 0 && request.resource.data.correctCount <= request.resource.data.solvedCount)) &&
            validShortText(request.resource.data.startNote, 160) &&
            validShortText(request.resource.data.reflection, 500) &&
            request.resource.data.startedAtMs is int && request.resource.data.endedAtMs is int;
          allow update: if false;
          allow delete: if appId == 'focusbell_v1' && isOwner(userId);
        }

        match /memos/{memoId} {
          allow read: if appId == 'focusbell_v1' && (isOwner(userId) || isAdmin());
          allow create, update: if appId == 'focusbell_v1' && isOwner(userId) &&
            request.resource.data.id == memoId &&
            request.resource.data.keys().hasOnly(['id', 'title', 'content', 'dateKey', 'pinned', 'createdAtMs', 'updatedAtMs']) &&
            validShortText(request.resource.data.title, 80) &&
            validShortText(request.resource.data.content, 2000) &&
            validDateKey(request.resource.data.dateKey) &&
            request.resource.data.pinned is bool;
          allow delete: if appId == 'focusbell_v1' && isOwner(userId);
        }

        match /plans/{planId} {
          allow read: if appId == 'focusbell_v1' && (isOwner(userId) || isAdmin());
          allow create, update: if appId == 'focusbell_v1' && isOwner(userId) &&
            request.resource.data.id == planId &&
            request.resource.data.keys().hasOnly([
              'id', 'title', 'dateKey', 'time', 'subject', 'note', 'done',
              'completedAtMs', 'reminderAtMs', 'notifiedAtMs',
              'createdAtMs', 'updatedAtMs'
            ]) &&
            validShortText(request.resource.data.title, 80) &&
            validDateKey(request.resource.data.dateKey) &&
            validShortText(request.resource.data.time, 5) &&
            validShortText(request.resource.data.subject, 30) &&
            validShortText(request.resource.data.note, 300) &&
            request.resource.data.done is bool &&
            request.resource.data.reminderAtMs is int &&
            request.resource.data.notifiedAtMs is int;
          allow delete: if appId == 'focusbell_v1' && isOwner(userId);
        }

        match /achievements/{achievementId} {
          allow read: if appId == 'focusbell_v1' && (isOwner(userId) || isAdmin());
          allow create, update: if appId == 'focusbell_v1' && isOwner(userId) &&
            request.resource.data.id == achievementId &&
            request.resource.data.keys().hasOnly(['id', 'met', 'emoji', 'title', 'body', 'priority', 'earnedAtMs', 'createdAtMs']) &&
            request.resource.data.met == true &&
            validShortText(request.resource.data.emoji, 8) &&
            validShortText(request.resource.data.title, 80) &&
            validShortText(request.resource.data.body, 240) &&
            request.resource.data.earnedAtMs is int;
          allow delete: if appId == 'focusbell_v1' && isOwner(userId);
        }
      }

      match /publicProfiles/{userId} {
        allow read: if appId == 'focusbell_v1' && signedIn();
        allow create, update: if appId == 'focusbell_v1' && isOwner(userId) &&
          request.resource.data.uid == userId &&
          request.resource.data.keys().hasOnly([
            'uid', 'displayName', 'handle', 'bio', 'showInRanking',
            'shareStudyStatus', 'showOnlineStatus', 'createdAtMs', 'updatedAtMs'
          ]) &&
          validShortText(request.resource.data.displayName, 24) &&
          validHandle(request.resource.data.handle) &&
          validShortText(request.resource.data.bio, 100) &&
          request.resource.data.showInRanking is bool &&
          request.resource.data.shareStudyStatus is bool &&
          request.resource.data.showOnlineStatus is bool;
        allow delete: if appId == 'focusbell_v1' && isOwner(userId);
      }

      match /publicStats/{userId} {
        allow read: if appId == 'focusbell_v1' && signedIn();
        allow create, update: if appId == 'focusbell_v1' && isOwner(userId) &&
          request.resource.data.uid == userId &&
          request.resource.data.keys().hasOnly([
            'uid', 'displayName', 'handle', 'todayKey', 'todayMinutes',
            'todaySolved', 'weekKey', 'weekMinutes', 'totalMinutes',
            'totalSolved', 'streak', 'sessionCount', 'isStudying',
            'currentSubject', 'sessionStartedAtMs', 'showInRanking',
            'shareStudyStatus', 'updatedAtMs'
          ]) &&
          validShortText(request.resource.data.displayName, 24) &&
          validHandle(request.resource.data.handle) &&
          validDateKey(request.resource.data.todayKey) &&
          validDateKey(request.resource.data.weekKey) &&
          request.resource.data.todayMinutes is int && request.resource.data.todayMinutes >= 0 &&
          request.resource.data.todaySolved is int && request.resource.data.todaySolved >= 0 &&
          request.resource.data.weekMinutes is int && request.resource.data.weekMinutes >= 0 &&
          request.resource.data.totalMinutes is int && request.resource.data.totalMinutes >= 0 &&
          request.resource.data.totalSolved is int && request.resource.data.totalSolved >= 0 &&
          request.resource.data.streak is int && request.resource.data.streak >= 0 &&
          request.resource.data.sessionCount is int && request.resource.data.sessionCount >= 0 &&
          request.resource.data.isStudying is bool &&
          validShortText(request.resource.data.currentSubject, 30) &&
          request.resource.data.showInRanking is bool &&
          request.resource.data.shareStudyStatus is bool;
        allow delete: if appId == 'focusbell_v1' && isOwner(userId);
      }

      match /presence/{userId} {
        allow read: if appId == 'focusbell_v1' && signedIn();
        allow create, update: if appId == 'focusbell_v1' && isOwner(userId) &&
          request.resource.data.uid == userId &&
          request.resource.data.keys().hasOnly([
            'uid', 'deviceId', 'visible', 'studying', 'subject',
            'displayName', 'handle', 'lastSeenAtMs', 'updatedAtMs'
          ]) &&
          validShortText(request.resource.data.deviceId, 120) &&
          request.resource.data.visible is bool &&
          request.resource.data.studying is bool &&
          validShortText(request.resource.data.subject, 30) &&
          validShortText(request.resource.data.displayName, 24) &&
          validHandle(request.resource.data.handle) &&
          request.resource.data.lastSeenAtMs is int;
        allow delete: if appId == 'focusbell_v1' && (isOwner(userId) || isAdmin());
      }


      match /adminPresence/{userId} {
        allow read: if appId == 'focusbell_v1' && (isOwner(userId) || isAdmin());
        allow create, update: if appId == 'focusbell_v1' && isOwner(userId) &&
          request.resource.data.uid == userId &&
          request.resource.data.keys().hasOnly([
            'uid', 'deviceId', 'visible', 'shareStudyStatus', 'studying',
            'subject', 'displayName', 'handle', 'lastSeenAtMs', 'updatedAtMs'
          ]) &&
          validShortText(request.resource.data.deviceId, 120) &&
          request.resource.data.visible is bool &&
          request.resource.data.shareStudyStatus is bool &&
          request.resource.data.studying is bool &&
          validShortText(request.resource.data.subject, 30) &&
          validShortText(request.resource.data.displayName, 24) &&
          validHandle(request.resource.data.handle) &&
          request.resource.data.lastSeenAtMs is int;
        allow delete: if appId == 'focusbell_v1' && (isOwner(userId) || isAdmin());
      }

      match /friendRequests/{requestId} {
        allow read: if appId == 'focusbell_v1' && signedIn() &&
          (request.auth.uid in resource.data.participantIds || isAdmin());
        allow create: if appId == 'focusbell_v1' && signedIn() &&
          request.resource.data.keys().hasOnly([
            'id', 'participantIds', 'fromId', 'toId', 'fromName',
            'fromHandle', 'toName', 'toHandle', 'status',
            'createdAtMs', 'updatedAtMs'
          ]) &&
          request.resource.data.id == requestId &&
          request.resource.data.fromId == request.auth.uid &&
          request.resource.data.fromId != request.resource.data.toId &&
          request.resource.data.participantIds is list &&
          request.resource.data.participantIds.size() == 2 &&
          request.resource.data.fromId in request.resource.data.participantIds &&
          request.resource.data.toId in request.resource.data.participantIds &&
          request.resource.data.status == 'pending' &&
          validShortText(request.resource.data.fromName, 24) &&
          validHandle(request.resource.data.fromHandle) &&
          validShortText(request.resource.data.toName, 24) &&
          validHandle(request.resource.data.toHandle) &&
          exists(/databases/$(database)/documents/apps/$(appId)/publicProfiles/$(request.resource.data.fromId)) &&
          exists(/databases/$(database)/documents/apps/$(appId)/publicProfiles/$(request.resource.data.toId)) &&
          get(/databases/$(database)/documents/apps/$(appId)/publicProfiles/$(request.resource.data.fromId)).data.displayName == request.resource.data.fromName &&
          get(/databases/$(database)/documents/apps/$(appId)/publicProfiles/$(request.resource.data.fromId)).data.handle == request.resource.data.fromHandle &&
          get(/databases/$(database)/documents/apps/$(appId)/publicProfiles/$(request.resource.data.toId)).data.displayName == request.resource.data.toName &&
          get(/databases/$(database)/documents/apps/$(appId)/publicProfiles/$(request.resource.data.toId)).data.handle == request.resource.data.toHandle;
        allow update: if false;
        allow delete: if appId == 'focusbell_v1' && signedIn() &&
          (request.auth.uid in resource.data.participantIds || isAdmin());
      }

      match /friendships/{friendshipId} {
        allow read: if appId == 'focusbell_v1' && signedIn() &&
          (request.auth.uid in resource.data.memberIds || isAdmin());
        allow create: if appId == 'focusbell_v1' && signedIn() &&
          request.resource.data.keys().hasOnly([
            'id', 'memberIds', 'userAId', 'userAName', 'userAHandle',
            'userBId', 'userBName', 'userBHandle', 'createdAtMs', 'updatedAtMs'
          ]) &&
          request.resource.data.id == friendshipId &&
          request.resource.data.memberIds is list &&
          request.resource.data.memberIds.size() == 2 &&
          request.resource.data.userAId in request.resource.data.memberIds &&
          request.resource.data.userBId in request.resource.data.memberIds &&
          exists(/databases/$(database)/documents/apps/$(appId)/friendRequests/$(friendshipId)) &&
          get(/databases/$(database)/documents/apps/$(appId)/friendRequests/$(friendshipId)).data.toId == request.auth.uid &&
          get(/databases/$(database)/documents/apps/$(appId)/friendRequests/$(friendshipId)).data.fromId in request.resource.data.memberIds &&
          get(/databases/$(database)/documents/apps/$(appId)/friendRequests/$(friendshipId)).data.toId in request.resource.data.memberIds;
        allow update: if false;
        allow delete: if appId == 'focusbell_v1' && signedIn() &&
          (request.auth.uid in resource.data.memberIds || isAdmin());
      }

      match /conversations/{conversationId} {
        allow read: if appId == 'focusbell_v1' && signedIn() &&
          (request.auth.uid in resource.data.memberIds || isAdmin());
        allow create: if appId == 'focusbell_v1' && signedIn() &&
          request.resource.data.keys().hasOnly([
            'id', 'memberIds', 'userAId', 'userAName', 'userAHandle',
            'userBId', 'userBName', 'userBHandle', 'lastMessagePreview',
            'lastMessageAtMs', 'lastSenderId', 'readAt', 'createdAtMs', 'updatedAtMs'
          ]) &&
          request.resource.data.id == conversationId &&
          request.resource.data.memberIds is list &&
          request.resource.data.memberIds.size() == 2 &&
          request.auth.uid in request.resource.data.memberIds &&
          request.resource.data.userAId in request.resource.data.memberIds &&
          request.resource.data.userBId in request.resource.data.memberIds &&
          request.resource.data.userAId != request.resource.data.userBId &&
          validShortText(request.resource.data.userAName, 24) &&
          validHandle(request.resource.data.userAHandle) &&
          validShortText(request.resource.data.userBName, 24) &&
          validHandle(request.resource.data.userBHandle) &&
          request.resource.data.lastMessagePreview == '' &&
          request.resource.data.lastMessageAtMs == 0 &&
          request.resource.data.lastSenderId == '' &&
          request.resource.data.readAt is map &&
          exists(/databases/$(database)/documents/apps/$(appId)/friendships/$(conversationId)) &&
          get(/databases/$(database)/documents/apps/$(appId)/friendships/$(conversationId)).data.memberIds == request.resource.data.memberIds;
        allow update: if appId == 'focusbell_v1' && signedIn() &&
          request.auth.uid in resource.data.memberIds &&
          request.resource.data.memberIds == resource.data.memberIds &&
          exists(/databases/$(database)/documents/apps/$(appId)/friendships/$(conversationId)) &&
          validShortText(request.resource.data.lastMessagePreview, 120) &&
          onlyOwnReadReceiptChanged() &&
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'lastMessagePreview', 'lastMessageAtMs', 'lastSenderId', 'readAt', 'updatedAtMs'
              ]) &&
              request.resource.data.lastSenderId == request.auth.uid &&
              request.resource.data.lastMessageAtMs is int &&
              request.resource.data.updatedAtMs is int &&
              request.resource.data.lastMessageAtMs == request.resource.data.updatedAtMs
            )
          );
        allow delete: if appId == 'focusbell_v1' && signedIn() &&
          (request.auth.uid in resource.data.memberIds || isAdmin());

        match /messages/{messageId} {
          allow read: if appId == 'focusbell_v1' && isConversationMember(appId, conversationId);
          allow create: if appId == 'focusbell_v1' && isConversationMember(appId, conversationId) &&
            request.resource.data.keys().hasOnly(['id', 'senderId', 'text', 'createdAtMs', 'clientId']) &&
            request.resource.data.id == messageId &&
            request.resource.data.senderId == request.auth.uid &&
            validShortText(request.resource.data.text, 1000) &&
            request.resource.data.text.size() > 0 &&
            request.resource.data.createdAtMs is int &&
            validShortText(request.resource.data.clientId, 120);
          allow update: if false;
          allow delete: if appId == 'focusbell_v1' && isConversationMember(appId, conversationId);
        }
      }

      match /posts/{postId} {
        allow read: if appId == 'focusbell_v1' && signedIn();
        allow create: if appId == 'focusbell_v1' && signedIn() &&
          request.resource.data.id == postId &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.keys().hasOnly([
            'id', 'authorId', 'authorName', 'authorHandle', 'content',
            'subject', 'likedBy', 'likeCount', 'createdAtMs', 'updatedAtMs'
          ]) &&
          validShortText(request.resource.data.authorName, 24) &&
          validHandle(request.resource.data.authorHandle) &&
          validShortText(request.resource.data.content, 500) &&
          validShortText(request.resource.data.subject, 30) &&
          request.resource.data.likedBy is list &&
          request.resource.data.likeCount == request.resource.data.likedBy.size();
        allow update: if appId == 'focusbell_v1' && signedIn() &&
          request.resource.data.authorId == resource.data.authorId &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.likeCount == request.resource.data.likedBy.size() &&
          (
            (
              request.auth.uid == resource.data.authorId &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'content', 'subject', 'authorName', 'authorHandle', 'updatedAtMs'
              ]) &&
              validShortText(request.resource.data.authorName, 24) &&
              validHandle(request.resource.data.authorHandle) &&
              validShortText(request.resource.data.content, 500) &&
              request.resource.data.content.size() > 0 &&
              validShortText(request.resource.data.subject, 30)
            ) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likeCount', 'updatedAtMs']) &&
              validLikeToggle()
            )
          );
        allow delete: if appId == 'focusbell_v1' && signedIn() &&
          (request.auth.uid == resource.data.authorId || isAdmin());

        match /comments/{commentId} {
          allow read: if appId == 'focusbell_v1' && signedIn();
          allow create: if appId == 'focusbell_v1' && signedIn() &&
            request.resource.data.id == commentId &&
            request.resource.data.authorId == request.auth.uid &&
            request.resource.data.keys().hasOnly([
              'id', 'authorId', 'authorName', 'authorHandle', 'content', 'createdAtMs'
            ]) &&
            validShortText(request.resource.data.authorName, 24) &&
            validHandle(request.resource.data.authorHandle) &&
            validShortText(request.resource.data.content, 300) &&
            request.resource.data.content.size() > 0;
          allow update: if false;
          allow delete: if appId == 'focusbell_v1' && signedIn() &&
            (request.auth.uid == resource.data.authorId ||
             request.auth.uid == get(/databases/$(database)/documents/apps/$(appId)/posts/$(postId)).data.authorId ||
             isAdmin());
        }
      }

      match /reports/{reportId} {
        allow create: if appId == 'focusbell_v1' && signedIn() &&
          request.resource.data.id == reportId &&
          request.resource.data.reporterId == request.auth.uid &&
          request.resource.data.status == 'open' &&
          request.resource.data.keys().hasOnly([
            'id', 'postId', 'postAuthorId', 'reporterId', 'reason',
            'createdAtMs', 'status'
          ]) &&
          validShortText(request.resource.data.reason, 120) &&
          exists(/databases/$(database)/documents/apps/$(appId)/posts/$(request.resource.data.postId)) &&
          get(/databases/$(database)/documents/apps/$(appId)/posts/$(request.resource.data.postId)).data.authorId == request.resource.data.postAuthorId;
        allow read: if appId == 'focusbell_v1' && signedIn() &&
          (resource.data.reporterId == request.auth.uid || isAdmin());
        allow update, delete: if appId == 'focusbell_v1' && isAdmin();
      }
    }
  }
}
